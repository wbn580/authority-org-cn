---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="页面未找到 — 全球主管部门信息汇编" description="你访问的页面不存在或已移动。">
  <section style="max-width:640px;margin:0 auto;padding:100px 20px;text-align:center">
    <p style="font-size:13px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#1f4e79;margin:0 0 14px">404</p>
    <h1 style="font-size:clamp(28px,5vw,44px);line-height:1.15;margin:0 0 16px">页面找不到</h1>
    <p style="font-size:17px;line-height:1.7;color:#556070;margin:0 0 32px">你要找的页面可能已移除、改名，或从未存在。</p>
    <a href="/" style="display:inline-flex;align-items:center;min-height:46px;padding:0 26px;border-radius:8px;background:#1f4e79;color:#fff;text-decoration:none;font-weight:700">返回首页</a>
  </section>
</BaseLayout>
