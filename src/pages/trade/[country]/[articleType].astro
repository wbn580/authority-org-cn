---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const domainMap: Record<string,{zh:string,desc:string}> = {
  immigration: { zh: '移民 / 签证', desc: '各国移民局、签证中心、边境管理机构官方公开信息汇编' },
  education: { zh: '教育', desc: '各国教育部、学历认证机构、留学监管机构官方公开信息汇编' },
  finance: { zh: '央行 / 金融监管', desc: '各国央行、证监会、银监会、金融监管机构官方公开信息汇编' },
  tax: { zh: '税务', desc: '各国国税部门、跨境税务条约官方公开信息汇编' },
  health: { zh: '卫生 / 医保', desc: '各国卫生部、医保系统、医师监管机构官方公开信息汇编' },
  legal: { zh: '司法 / 法务', desc: '各国司法部、律师监管、仲裁机构官方公开信息汇编' },
  trade: { zh: '贸易 / 海关', desc: '各国海关、贸易部、跨境电商监管机构官方公开信息汇编' },
  labor: { zh: '劳工 / 就业', desc: '各国劳工部、就业服务、工资监管机构官方公开信息汇编' },
  transport: { zh: '交通 / 民航', desc: '各国民航局、交通部、跨境物流监管机构官方公开信息汇编' },
};

const countryLabels: Record<string,string> = {
  au:'澳大利亚',uk:'英国',us:'美国',ca:'加拿大',nz:'新西兰',sg:'新加坡',
  hk:'香港',jp:'日本',my:'马来西亚',kr:'韩国',th:'泰国',id:'印尼',vn:'越南',ph:'菲律宾',
  fr:'法国',de:'德国',nl:'荷兰',ch:'瑞士',ie:'爱尔兰',es:'西班牙',it:'意大利',
  ae:'阿联酋',il:'以色列',cn:'中国大陆',tw:'中国台湾',mo:'中国澳门',
};

export function getStaticPaths() {
  const countryLabels = {
    au:'澳大利亚',uk:'英国',us:'美国',ca:'加拿大',nz:'新西兰',sg:'新加坡',
    hk:'香港',jp:'日本',my:'马来西亚',kr:'韩国',th:'泰国',id:'印尼',vn:'越南',ph:'菲律宾',
    fr:'法国',de:'德国',nl:'荷兰',ch:'瑞士',ie:'爱尔兰',es:'西班牙',it:'意大利',
    ae:'阿联酋',il:'以色列',cn:'中国大陆',tw:'中国台湾',mo:'中国澳门',
  };
  const domain = 'trade';
  const paths: Array<{params:{country:string,articleType:string},props:{domain:string,zh:string}}> = [];
  for (const [code, zh] of Object.entries(countryLabels)) {
    for (const at of ['overview','functions','history','policy_update','comparison','faq','contact_guide']) {
      paths.push({
        params: { country: code, articleType: at },
        props: { domain, zh }
      });
    }
  }
  return paths;
}

const { domain, zh } = Astro.props;
const { country, articleType } = Astro.params;
const d = domainMap[domain];

const allArticles = await getCollection('articles');
const entry = allArticles.find(a => 
  a.data.category === domain && a.data.country === country && a.data.articleType === articleType
);
const article = entry?.data;
const { Content } = entry ? await entry.render() : { Content: null };
---

<BaseLayout title={article ? article.title + ' — 全球主管部门信息汇编' : `${zh}${d.zh} — 全球主管部门信息汇编`} description={article ? article.description : d.desc}>
  <div class="max-w-4xl mx-auto px-4 py-10">

    <nav class="text-sm text-ink-500 mb-6">
      <a href="/" class="text-accent-600 no-underline">首页</a>
      <span class="mx-2">/</span>
      <a href={`/${domain}/`} class="text-accent-600 no-underline">{d.zh}</a>
      <span class="mx-2">/</span>
      <a href={`/${domain}/${country}/`} class="text-accent-600 no-underline">{zh}</a>
      <span class="mx-2">/</span>
      <span class="text-ink-700">{article ? article.title : articleType}</span>
    </nav>

    {article ? (
      <article class="prose prose-lg max-w-none">
        <div class="mb-8 pb-6 border-b border-divider">
          <h1 class="text-2xl sm:text-3xl font-serif font-bold text-primary-900 m-0 mb-3">{article.title}</h1>
          <div class="flex flex-wrap gap-2 text-xs text-ink-500">
            {article.publishDate && (
              <span>发布日期：{new Date(article.publishDate).toLocaleDateString('zh-CN')}</span>
            )}
            {article.lastVerified && (
              <span>· 最后核实：{article.lastVerified}</span>
            )}
            <span>· 阅读时间：{article.readingTime || '?'} 分钟</span>
            {article.country && (
              <span>· {countryLabels[article.country] || article.country.toUpperCase()}</span>
            )}
          </div>
        </div>
        <div class="article-body">
          {Content && <Content />}
        </div>
      </article>
    ) : (
      <div class="p-6 bg-paper-100 rounded-lg border border-divider text-center">
        <p class="text-ink-500 m-0">该文章正在整理中，敬请期待。</p>
      </div>
    )}

    <div class="mt-10 text-center">
      <a href={`/${domain}/${country}/`} class="inline-block text-sm text-accent-600 no-underline font-medium border border-accent-600 rounded-full px-4 py-2 hover:bg-accent-50 transition-colors">
        ← 返回{zh}{d.zh}文章列表
      </a>
    </div>

  </div>
</BaseLayout>
