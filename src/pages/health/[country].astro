---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const domainMap = {
  immigration: { zh: '移民 / 签证', desc: '各国移民局、签证中心、边境管理机构官方公开信息汇编' },
  education: { zh: '教育', desc: '各国教育部、学历认证机构、留学监管机构官方公开信息汇编' },
  finance: { zh: '央行 / 金融监管', desc: '各国央行、证监会、银监会、金融监管机构官方公开信息汇编' },
  tax: { zh: '税务', desc: '各国国税部门、跨境税务条约官方公开信息汇编' },
  health: { zh: '卫生 / 医保', desc: '各国卫生部、医保系统、医师监管机构官方公开信息汇编' },
  legal: { zh: '司法 / 法务', desc: '各国司法部、律师监管、仲裁机构官方公开信息汇编' },
  trade: { zh: '贸易 / 海关', desc: '各国海关、贸易部、跨境电商监管机构官方公开信息汇编' },
  labor: { zh: '劳工 / 就业', desc: '各国劳工部、就业服务、工资监管机构官方公开信息汇编' },
  transport: { zh: '交通 / 民航', desc: '各国民航局、交通部、跨境物流监管机构官方公开信息汇编' },
};

export function getStaticPaths() {
  const countries = [
    { code: 'au', zh: '澳大利亚' },{ code: 'uk', zh: '英国' },{ code: 'us', zh: '美国' },{ code: 'ca', zh: '加拿大' },{ code: 'nz', zh: '新西兰' },{ code: 'sg', zh: '新加坡' },{ code: 'hk', zh: '香港' },{ code: 'jp', zh: '日本' },{ code: 'my', zh: '马来西亚' },{ code: 'kr', zh: '韩国' },{ code: 'th', zh: '泰国' },{ code: 'id', zh: '印尼' },{ code: 'vn', zh: '越南' },{ code: 'ph', zh: '菲律宾' },{ code: 'fr', zh: '法国' },{ code: 'de', zh: '德国' },{ code: 'nl', zh: '荷兰' },{ code: 'ch', zh: '瑞士' },{ code: 'ie', zh: '爱尔兰' },{ code: 'es', zh: '西班牙' },{ code: 'it', zh: '意大利' },{ code: 'ae', zh: '阿联酋' },{ code: 'il', zh: '以色列' },{ code: 'cn', zh: '中国大陆' },{ code: 'tw', zh: '中国台湾' },{ code: 'mo', zh: '中国澳门' },
  ];
  const domain = 'health';
  return countries.map(c => ({
    params: { country: c.code },
    props: { domain, code: c.code, zh: c.zh }
  }));
}

const { domain, code, zh } = Astro.props;
const d = domainMap[domain];

const allArticles = await getCollection('articles');
const articles = allArticles.filter(a => 
  a.data.category === domain && a.data.country === code
);

const typeOrder = ['overview','functions','history','policy_update','comparison','faq','contact_guide'];
const sorted = articles.sort((a,b) => {
  const ai = typeOrder.indexOf(a.data.articleType);
  const bi = typeOrder.indexOf(b.data.articleType);
  return ai - bi;
});
---

<BaseLayout title={`${zh}${d.zh}主管部门 — 全球主管部门信息汇编`} description={`${zh}${d.desc}`}>
  <div class="max-w-6xl mx-auto px-4 py-10">

    <nav class="text-sm text-ink-500 mb-6">
      <a href="/" class="text-accent-600 no-underline">首页</a>
      <span class="mx-2">/</span>
      <a href={`/${domain}/`} class="text-accent-600 no-underline">{d.zh}</a>
      <span class="mx-2">/</span>
      <span class="text-ink-700">{zh}</span>
    </nav>

    <h1 class="text-2xl font-serif font-bold text-primary-900 mb-2">{zh}{d.zh}主管部门</h1>
    <p class="text-ink-500 mb-8">{d.desc}</p>

    {sorted.length === 0 ? (
      <div class="p-6 bg-paper-100 rounded-lg border border-divider text-center">
        <p class="text-ink-500 m-0">该国家/地区的{d.zh}详细文章正在整理中，敬请期待。</p>
      </div>
    ) : (
      <div class="space-y-6">
        {sorted.map(article => (
          <a href={`/${domain}/${code}/${article.data.articleType}/`} class="no-underline block bg-white border border-divider rounded-lg p-5 hover:border-primary-500 hover:shadow-md transition-all">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-base font-serif font-semibold text-primary-700 m-0 mb-1">{article.data.title}</h2>
                <p class="text-sm text-ink-500 m-0 line-clamp-2">{article.data.description}</p>
              </div>
              <div class="flex-shrink-0 text-right">
                <span class="text-xs text-ink-400">{article.data.readingTime || '?'} 分钟阅读</span>
                {article.data.publishDate && (
                  <p class="text-xs text-ink-400 m-0 mt-1">{new Date(article.data.publishDate).toLocaleDateString('zh-CN')}</p>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="mt-10 text-center">
      <a href={`/countries/${code}/`} class="inline-block text-sm text-accent-600 no-underline font-medium border border-accent-600 rounded-full px-4 py-2 hover:bg-accent-50 transition-colors">
        ← 返回{zh}主管部门索引
      </a>
    </div>

  </div>
</BaseLayout>
