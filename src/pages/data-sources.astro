import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="数据来源 — 全球主管部门信息汇编" description="本站所引用的各机构官方网站、政府数据库、议会档案等数据来源清单">
  <div class="max-w-article mx-auto px-4 py-10">
    <h1 class="text-2xl font-serif font-bold text-primary-900 mb-6">数据来源</h1>
    <div class="prose max-w-none">
      <p>本站数据全部来自各机构的<strong>公开渠道</strong>，按国家分类列出主要数据源：</p>
      
      <h2>澳大利亚（AU）</h2>
      <ul>
        <li>Department of Home Affairs — immi.homeaffairs.gov.au</li>
        <li>Australian Taxation Office — ato.gov.au</li>
        <li>Reserve Bank of Australia — rba.gov.au</li>
        <li>Department of Education — education.gov.au</li>
        <li>Department of Health and Aged Care — health.gov.au</li>
        <li>Attorney-General's Department — ag.gov.au</li>
        <li>Australian Border Force — abf.gov.au</li>
        <li>Department of Employment and Workplace Relations — dewr.gov.au</li>
      </ul>

      <h2>英国（UK）</h2>
      <ul>
        <li>UK Visas and Immigration — gov.uk/ukvi</li>
        <li>HM Revenue & Customs — gov.uk/hmrc</li>
        <li>Bank of England — bankofengland.co.uk</li>
        <li>Department for Education — gov.uk/dfe</li>
        <li>Department of Health and Social Care — gov.uk/dhsc</li>
        <li>Ministry of Justice — gov.uk/moj</li>
      </ul>

      <h2>美国（US）</h2>
      <ul>
        <li>USCIS — uscis.gov</li>
        <li>Internal Revenue Service — irs.gov</li>
        <li>Federal Reserve — federalreserve.gov</li>
        <li>Department of Education — ed.gov</li>
        <li>Department of Health and Human Services — hhs.gov</li>
        <li>Department of Justice — justice.gov</li>
      </ul>

      <p class="mt-8 text-sm text-ink-500">以上为部分代表性数据源。每篇文章末尾均列有该文的具体数据来源。完整数据来源覆盖 26 个国家、九大职能领域，详见各篇文章。</p>
      <p class="text-sm text-ink-500">本站不采集任何非公开信息。所有引述均可在公开渠道验证。</p>
    </div>
  </div>
</BaseLayout>
