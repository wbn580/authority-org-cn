---
// BaseHead.astro — Common <head> elements
const { title = '全球主管部门信息汇编', description = '全球主管部门信息汇编 — 独立运营的各国政府部门/主管机构/监管机构公开信息汇编平台' } = Astro.props;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
<link rel="alternate" hreflang="zh-CN" href={new URL(Astro.url.pathname, Astro.site).href} />
<link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname, Astro.site).href} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="全球主管部门信息汇编" />
<meta property="og:locale" content="zh_CN" />
<meta property="og:image" content={new URL('/og-default.svg', Astro.site).href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={new URL('/og-default.svg', Astro.site).href} />

<!-- Fonts: Noto Serif HK + Noto Sans HK -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+HK:wght@400;500;600&family=Noto+Serif+HK:wght@500;600;700&display=swap" rel="stylesheet" />

<!-- Structured data -->
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "全球主管部门信息汇编",
  "alternateName": "Global Government Authority Registry",
  "url": "https://authority.org.cn",
  "description": "独立运营的各国政府部门、主管机构、监管机构公开信息汇编平台",
  "inLanguage": "zh-CN",
  "publisher": {
    "@type": "Organization",
    "name": "全球主管部门信息汇编编辑组",
    "url": "https://authority.org.cn/about"
  }
}
</script>
