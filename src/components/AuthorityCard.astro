---
// AuthorityCard.astro — Government authority profile card
const { authority } = Astro.props;
---
<div class="authority-card">
  <div class="flex items-start gap-3 mb-3">
    <!-- Flag placeholder -->
    <div class="w-10 h-10 rounded bg-primary-50 flex items-center justify-center text-xs font-semibold text-primary-500 flex-shrink-0">
      {authority.country?.toUpperCase() || '?'}
    </div>
    <div>
      <h3 class="text-base font-serif font-semibold m-0 text-primary-700">{authority.full_name_zh || authority.full_name_en}</h3>
      {authority.full_name_en && authority.full_name_zh && (
        <p class="text-xs text-ink-500 m-0 mt-0.5">{authority.full_name_en}</p>
      )}
      {authority.abbreviation && (
        <p class="text-xs text-accent-600 m-0 mt-0.5 font-medium">{authority.abbreviation}</p>
      )}
    </div>
  </div>
  
  <div class="text-xs text-ink-500 space-y-1">
    {authority.scope && <p class="m-0"><strong>主管领域：</strong>{authority.scope}</p>}
    {authority.headquartered && <p class="m-0"><strong>总部：</strong>{authority.headquartered}</p>}
    {authority.established && <p class="m-0"><strong>成立：</strong>{authority.established}</p>}
    {authority.official_url && (
      <p class="m-0"><strong>官网：</strong><a href={authority.official_url} class="text-xs" target="_blank" rel="noopener">{authority.official_url}</a></p>
    )}
  </div>

  {authority.slug && (
    <div class="mt-3 pt-3 border-t border-divider">
      <a href={`/authorities/${authority.slug}`} class="text-xs text-primary-500 no-underline hover:text-accent-600">
        查看详情 →
      </a>
    </div>
  )}
</div>
