---
// ArticleDisclaimer.astro — Per-article disclaimer footer
const { dataSources = [], publishDate = new Date().toISOString().split('T')[0] } = Astro.props;
---
<div class="mt-12 pt-8 border-t-2 border-divider text-sm text-ink-500">
  
  <!-- Data Sources -->
  {dataSources.length > 0 && (
    <section class="mb-6">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-primary-700 mb-2 font-sans">数据来源</h4>
      <ul class="space-y-1" style="list-style:none;padding:0;margin:0;">
        {dataSources.map((source: any) => (
          <li class="text-xs leading-relaxed">
            - {source.name}{source.url ? `（${source.url}）` : ''}{source.year ? ` · ${source.year}` : ''}
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Verification date -->
  <section class="mb-6">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-primary-700 mb-2 font-sans">本文整理日期</h4>
    <p class="text-xs m-0">{publishDate}</p>
  </section>

  <!-- Political neutrality -->
  <section class="mb-6 p-4 bg-warning-50 border-l-4 border-warning-500 rounded-r">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-warning-500 mb-2 font-sans">政治中立声明</h4>
    <p class="text-xs m-0 leading-relaxed">
      本文对所述国家 / 地区的政府政策、监管规定不作任何政治评价。本文仅整理公开信息，不站队、不预测、不评判。
    </p>
  </section>

  <!-- Full disclaimer -->
  <section class="p-4 bg-paper-100 border border-divider rounded">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-primary-700 mb-2 font-sans">免责声明</h4>
    <p class="text-xs m-0 leading-relaxed">
      本文内容为公开信息汇编，<strong>仅供参考</strong>。本文不构成法律、移民、税务、金融或任何形式的专业建议。涉及您本人申请、申报、跨境业务等重要决策时，请直接咨询相应<strong>持牌专业人士</strong>或访问<strong>各国 / 各地区官方机构渠道</strong>。本文数据可能存在更新延迟，最终以相应官方机构公告为准。
    </p>
  </section>
</div>
